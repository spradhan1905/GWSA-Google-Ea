# backend/.env.example — commit this file, NOT .env

SQL_SERVER=hqdata
SQL_DATABASE=JS_API
SQL_DRIVER={ODBC Driver 17 for SQL Server}

# --- Auth: pick ONE approach ---
# Windows Integrated Security (local / domain; no SQL user). Requires pyodbc + ODBC driver on Windows.
SQL_USE_WINDOWS_AUTH=True
# Leave these empty when using Windows auth:
SQL_USERNAME=
SQL_PASSWORD=

# SQL login (when SQL_USE_WINDOWS_AUTH=False)
# SQL_USERNAME=gwsa_app_user
# SQL_PASSWORD=REPLACE_WITH_REAL_PASSWORD
# Line-level sales (Core Sales, Revenue, Soldts, sales unit name, SoldStoreId)
SQL_SALES_LINE_OBJECT=JS_API.dbo.SalesFactFinal

# Locations: static = backend/db/static_locations.py (no dbo.Locations in SQL). database = use SQL_LOCATIONS_TABLE.
LOCATIONS_SOURCE=static
# Only if LOCATIONS_SOURCE=database — optional migration: models/migrations/001_locations_add_sales_keys.sql
SQL_LOCATIONS_TABLE=dbo.Locations
# SalesCategoryFromGP filter. Leave empty to include all line categories (use if MTD is 0).
SQL_SALES_CORE_CATEGORY=Core Sales
# true = match [sales unit name] if GP name is shorter or substring of app name
SQL_SALES_UNIT_NAME_FLEXIBLE=True
# True = name/numeric-ID join only. False = use SoldStoreId + SalesStoreUnit on dbo.Locations (after migration).
SQL_LOCATIONS_MINIMAL_JOIN=True

# Door counts (PeopleCounter database). Grant SELECT on this table to the app login / Windows user.
SQL_DOOR_COUNT_OBJECT=PeopleCounter.dbo.PCounter
# PCounter columns: hourly rows are summed to daily In totals in SQL. LocationID = numeric sensor/site id.
SQL_DOOR_COUNT_COL_DATE=Date
SQL_DOOR_COUNT_COL_VISITS=In
SQL_DOOR_COUNT_COL_LOCATION=LocationID
# Per app store, set pcounter_location_ids in static_locations.py (or DB) to every PCounter LocationID for that site (e.g. Left + Right = two ints).

GEMINI_API_KEY=REPLACE_WITH_REAL_KEY
FLASK_SECRET_KEY=REPLACE_WITH_32_CHAR_RANDOM_STRING
FLASK_DEBUG=False

# Update to production domain before deploying
CORS_ORIGIN=http://localhost:5173
